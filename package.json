{
  "name": "codex-repo-doctor-workspace",
  "version": "0.1.0",
  "description": "Workspace for Codex Repo Doctor, a CLI for repository readiness checks.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.6"
  },
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "doctor": "node packages/codex-repo-doctor/src/index.ts doctor --root .",
    "test": "node --test packages/codex-repo-doctor/test/*.test.ts",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "lint": "node packages/codex-repo-doctor/src/lint.ts",
    "build": "tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^6.0.3"
  }
}
